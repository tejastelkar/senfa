{% comment %}
  Senfa — Hyper-Premium Benefits Section (Standardized Centered Header)
  File: sections/senfa-benefits.liquid
{% endcomment %}

<section class="senfa-benefits" id="senfa-benefits-{{ section.id }}" style="
  --bg-color: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --accent-gold: {{ section.settings.accent_gold }};
  --text-dark: {{ section.settings.text_dark }};
  --text-light: {{ section.settings.text_light }};
  --strip-border: {{ section.settings.accent_gold | color_modify: 'alpha', 0.2 }};
">

  <div class="senfa-benefits__inner">
    
    {%- comment -%} ── STANDARDIZED UTILITY HEADER (Clean & Centered) ── {%- endcomment -%}
    <div class="senfa-benefits__header-standard">
      {%- if section.settings.heading != blank -%}
        <h2 class="senfa-benefits__heading-centered">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} The Open Grid {%- endcomment -%}
    <div class="senfa-benefits__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'benefit' -%}
          <div class="senfa-benefit-card" {{ block.shopify_attributes }}>
            
            <span class="senfa-benefit-card__ghost">0{{ forloop.index }}</span>

            <div class="senfa-benefit-card__content">
              {%- if block.settings.svg_code != blank -%}
                <div class="senfa-benefit-card__icon">
                  {{ block.settings.svg_code }}
                </div>
              {%- endif -%}

              <div class="senfa-benefit-card__line"></div>

              {%- if block.settings.title != blank -%}
                <h3 class="senfa-benefit-card__title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="senfa-benefit-card__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  {%- comment -%} Elegant Bottom Strip {%- endcomment -%}
  {%- if section.settings.show_strip -%}
    <div class="senfa-benefits__strip-wrap">
      <div class="senfa-benefits__strip">
        <div class="senfa-benefits__strip-item"><span class="senfa-diamond"></span> 0% Sulphate</div>
        <div class="senfa-benefits__strip-item"><span class="senfa-diamond"></span> 0% Paraben</div>
        <div class="senfa-benefits__strip-item"><span class="senfa-diamond"></span> 0% Silicones</div>
        <div class="senfa-benefits__strip-item"><span class="senfa-diamond"></span> 100% Vegan</div>
        <div class="senfa-benefits__strip-item"><span class="senfa-diamond"></span> Himalayan Origin</div>
        <div class="senfa-benefits__strip-item"><span class="senfa-diamond"></span> Cruelty Free</div>
      </div>
    </div>
  {%- endif -%}

</section>

<style>
/* ════════════════════════════════
   SENFA — BENEFITS ARCHITECTURE
════════════════════════════════ */

.senfa-benefits {
  background-color: var(--bg-color);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.senfa-benefits__inner {
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 80px;
}

/* ══════════════════════════════════════════════
   STANDARDIZED CENTERED HEADER
══════════════════════════════════════════════ */

.senfa-benefits__header-standard {
  text-align: center;
  max-width: 1600px;
  margin: 0 auto 80px; /* Matched to the old padding */
  padding: 0 40px;
}

.senfa-benefits__heading-centered {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 4.5vw, 56px);
  font-weight: 400;
  color: var(--heading-color);
  margin: 0;
  letter-spacing: -0.01em;
  text-transform: none !important;
}

/* ── The Open Grid ── */
.senfa-benefits__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px; /* Open space instead of borders */
}

/* ── Individual Cards ── */
.senfa-benefit-card {
  position: relative;
  padding: 20px 0;
  cursor: default;
  transition: transform 0.4s ease;
}

.senfa-benefit-card:hover {
  transform: translateY(-8px); /* Subtle luxury float */
}

/* The Ghost Number */
.senfa-benefit-card__ghost {
  position: absolute;
  top: -40px;
  right: -10px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 140px;
  font-weight: 300;
  line-height: 1;
  color: var(--accent-gold);
  opacity: 0.04; /* Barely visible */
  z-index: -1;
  user-select: none;
  pointer-events: none;
  transition: opacity 0.4s ease, transform 0.4s ease;
}

.senfa-benefit-card:hover .senfa-benefit-card__ghost {
  opacity: 0.08;
  transform: translateY(-4px) scale(1.05);
}

.senfa-benefit-card__content {
  position: relative;
  z-index: 2;
}

/* Ultra-thin SVGs */
.senfa-benefit-card__icon {
  width: 40px;
  height: 40px;
  margin-bottom: 32px;
}
.senfa-benefit-card__icon svg {
  width: 100%;
  height: 100%;
  stroke-width: 1.2px;
  display: block;
}

/* Elegant separator */
.senfa-benefit-card__line {
  width: 24px;
  height: 1px;
  background: var(--accent-gold);
  margin-bottom: 24px;
  transition: width 0.4s ease;
}
.senfa-benefit-card:hover .senfa-benefit-card__line {
  width: 48px; /* Expands smoothly on hover */
}

/* Typography */
.senfa-benefit-card__title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 26px;
  font-weight: 400;
  color: var(--heading-color);
  margin: 0 0 16px;
  line-height: 1.1;
}

.senfa-benefit-card__desc {
  font-family: 'Jost', sans-serif;
  font-size: 14.5px;
  color: var(--text-light);
  line-height: 1.7;
  font-weight: 300;
  margin: 0;
  max-width: 90%;
}

/* ── Elegant Bottom Strip ── */
.senfa-benefits__strip-wrap {
  margin-top: 80px;
  border-top: 1px solid var(--strip-border);
  border-bottom: 1px solid var(--strip-border);
  padding: 24px 0;
  overflow: hidden;
}

.senfa-benefits__strip {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 32px 64px;
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 80px;
}

  .senfa-benefits__strip-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  color: var(--text-dark);
  font-weight: 500;
  white-space: nowrap;
}

.senfa-diamond {
  width: 4px;
  height: 4px;
  background: var(--accent-gold);
  transform: rotate(45deg);
  display: inline-block;
  opacity: 0.6;
}

/* ════════════════
   TABLET 1024px
════════════════ */
@media (max-width: 1024px) {
  .senfa-benefits__inner {
    padding: 0 56px;
  }
  .senfa-benefits__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 64px 40px;
  }
  .senfa-benefits__strip {
    padding: 0 56px;
    gap: 24px 40px;
  }
}

/* ════════════════
   MOBILE 768px
════════════════ */
@media (max-width: 768px) {
  .senfa-benefits {
    padding: 80px 0 60px;
  }
  .senfa-benefits__inner {
    padding: 0 24px;
  }
  .senfa-benefits__header-standard {
    padding: 0;
    margin-bottom: 48px;
  }
  .senfa-benefits__heading-centered {
    font-size: 36px;
  }
  .senfa-benefits__grid {
    grid-template-columns: 1fr;
    gap: 56px;
  }
  .senfa-benefit-card {
    padding: 0;
  }
  .senfa-benefit-card__ghost {
    right: 0;
  }
  .senfa-benefits__strip-wrap {
    margin-top: 64px;
    padding: 24px 0;
  }
  .senfa-benefits__strip {
    padding: 0 24px;
    justify-content: flex-start;
    gap: 20px 40px;
  }
}
</style>


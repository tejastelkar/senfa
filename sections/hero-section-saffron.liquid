<section class="senfa-hero">

  <!-- Inner wrapper to match story section width -->
  <div class="senfa-hero__inner">

    <!-- LEFT PANEL -->
    <div class="senfa-left">

      <!-- Tagline -->
      <div class="senfa-fade-up senfa-tagline" style="animation-delay:0.1s;">
        <div class="senfa-line"></div>
        <span>{{ section.settings.tagline }}</span>
      </div>

      <!-- Headline -->
      <h1 class="senfa-fade-up senfa-h1" style="animation-delay:0.25s;">
        <span class="senfa-word">{{ section.settings.heading_line1 }} <em>{{ section.settings.heading_italic }}</em></span>
        <span class="senfa-word">{{ section.settings.heading_line2 }}</span>
      </h1>

      <!-- Body -->
      <p class="senfa-fade-up senfa-body" style="animation-delay:0.4s;">
        {{ section.settings.body_text }}
      </p>

      <!-- Badges -->
      <div class="senfa-fade-up senfa-badges" style="animation-delay:0.55s;">
        {%- if section.settings.badge_1 != blank -%}
          <span class="senfa-badge"><span class="senfa-dot"></span>{{ section.settings.badge_1 }}</span>
        {%- endif -%}
        {%- if section.settings.badge_2 != blank -%}
          <span class="senfa-badge"><span class="senfa-dot"></span>{{ section.settings.badge_2 }}</span>
        {%- endif -%}
        {%- if section.settings.badge_3 != blank -%}
          <span class="senfa-badge"><span class="senfa-dot"></span>{{ section.settings.badge_3 }}</span>
        {%- endif -%}
      </div>

      <!-- Buttons -->
      <div class="senfa-fade-up senfa-btns" style="animation-delay:0.7s;">
        <a href="{{ section.settings.btn_primary_url }}" class="senfa-btn-primary"><span>{{ section.settings.btn_primary_label }} &rarr;</span></a>
        <a href="{{ section.settings.btn_ghost_url }}" class="senfa-btn-ghost">{{ section.settings.btn_ghost_label }} &rarr;</a>
      </div>

    </div>

    <!-- RIGHT PANEL -->
    <div class="senfa-right">

      <div class="senfa-watermark">{{ section.settings.watermark_text }}</div>

      <div class="senfa-fade-up senfa-origin" style="animation-delay:0.5s;">
        <p class="senfa-origin-label">{{ section.settings.origin_label }}</p>
        <p class="senfa-origin-value">{{ section.settings.origin_value }}</p>
      </div>

      <div class="senfa-fade-up senfa-imgwrap" style="animation-delay:0.35s;">
        {%- if section.settings.product_image != blank -%}
          <img
    src="{{ section.settings.product_image | image_url: width: 1000 }}"
    alt="{{ section.settings.product_image.alt | default: section.settings.heading_line1 }}"
    width="{{ section.settings.product_image.width | default: 1000 }}"
    height="{{ section.settings.product_image.height | default: 1000 }}"
    class="senfa-img">
        {%- else -%}
          <img
    src="https://cdn.shopify.com/s/files/1/0670/1809/6849/files/product.png?v=1774638764"
    alt="Senfa Himalayan Saffron Bath Soap"
    width="1000"
    height="1000"
    class="senfa-img">
        {%- endif -%}
      </div>

      <div class="senfa-fade-up senfa-price" style="animation-delay:0.6s;">
        <p class="senfa-price-label">{{ section.settings.price_label }}</p>
        <p class="senfa-price-amount">{{ section.settings.price_amount }}</p>
        <p class="senfa-price-sub">{{ section.settings.price_subtext }}</p>
      </div>

    </div>

  </div>

  <!-- SCROLL -->
  <div class="senfa-scroll">
    <span class="senfa-scroll-text">Scroll</span>
    <div class="senfa-scroll-track">
      <div class="senfa-scroll-bar"></div>
    </div>
  </div>

</section>

<style>
.shopify-section:has(.senfa-hero) {
  padding: 0 !important;
  margin: 0 !important;
}

/* ── Hero ── */
.senfa-hero {
  background: linear-gradient(135deg, #2D1B4E 0%, #4A2D78 40%, #3D2468 70%, #2D1B4E 100%);
  height: calc(96vh - 75px);
  max-height: 900px;
  min-height: 560px;
  display: flex;
  align-items: stretch;
  justify-content: center;
  position: relative;
  margin: 0;
  overflow: hidden;
  isolation: isolate;
}

/* ── Inner wrapper — matches story section ── */
.senfa-hero__inner {
  max-width: 1600px;
  width: 100%;
  margin: 0 auto;
  padding: 0 80px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  box-sizing: border-box;
}

/* ── LEFT ── */
.senfa-left {
  padding: 0px 60px 0px 0px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: transparent;
  position: relative;
  z-index: 2;
}

/* Tagline */
.senfa-tagline {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}
.senfa-tagline span {
  font-family: 'Jost', sans-serif;
  font-size: 9.5px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #E0B84E;
  font-weight: 300;
}
.senfa-line {
  width: 40px;
  height: 1.5px;
  background: #C9922A;
  flex-shrink: 0;
}

/* Headline */
.senfa-h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 80px;
  font-weight: 400;
  line-height: 1.05;
  color: #FEFCF8;
  margin: 0 0 20px;
  letter-spacing: -1px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.senfa-word {
  display: block;
}
.senfa-h1 em {
  color: #E0B84E;
  font-style: italic;
  font-weight: 400;
}

/* Body */
.senfa-body {
  font-family: 'Jost', sans-serif;
  font-size: 16px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
  max-width: 460px;
  margin-bottom: 20px;
}

/* Badges */
.senfa-badges {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 28px;
  flex-wrap: wrap;
}
.senfa-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.45);
  font-weight: 300;
}
.senfa-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #C9922A;
  flex-shrink: 0;
  display: inline-block;
}

/* Buttons */
.senfa-btns {
  display: flex;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}
.senfa-btn-primary {
  background: linear-gradient(135deg, #C9922A 0%, #E0B84E 100%);
  color: #2D1B4E !important;
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 15px 32px;
  text-decoration: none !important;
  font-weight: 600;
  display: inline-block;
  position: relative;
  overflow: hidden;
  z-index: 0;
  border-radius: 2px;
  box-shadow: 0 8px 28px rgba(201,146,42,0.38);
  transition: all 0.3s;
}
.senfa-btn-primary span {
  position: relative;
  z-index: 2;
  color: #2D1B4E !important;
  pointer-events: none;
}
.senfa-btn-primary:hover {
  box-shadow: 0 12px 36px rgba(201,146,42,0.52);
  transform: translateY(-2px);
}

.senfa-btn-ghost {
  color: rgba(255, 255, 255, 0.55);
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  text-decoration: none !important;
  font-weight: 300;
  position: relative;
  padding-bottom: 3px;
  transition: color 0.3s ease;
}
.senfa-btn-ghost::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 0%;
  height: 1px;
  background: #E0B84E;
  transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.senfa-btn-ghost:hover::after { width: 100%; }
.senfa-btn-ghost:hover { color: #E0B84E; }

/* ── RIGHT ── */
.senfa-right {
  position: relative;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  isolation: isolate;
}

/* Radial glow behind product */
.senfa-right::before {
  content: '';
  position: absolute;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,146,42,0.16) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 1;
}

.senfa-watermark {
  position: absolute;
  bottom: 20px;
  left: 0px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 100px;
  font-weight: 300;
  color: rgba(255,255,255,0.05);
  letter-spacing: 12px;
  text-transform: uppercase;
  white-space: nowrap;
  pointer-events: none;
  user-select: none;
  line-height: 1;
}

.senfa-origin {
  position: absolute;
  top: 24px;
  right: 32px;
  text-align: right;
}
.senfa-origin-label {
  font-family: 'Jost', sans-serif;
  font-size: 8px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  margin: 0 0 4px;
  font-weight: 300;
}
.senfa-origin-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  font-style: italic;
  color: #C9922A;
  font-weight: 300;
  margin: 0;
}

.senfa-imgwrap {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48px 32px;
}
.senfa-img {
  width: auto;
  height: 100%;
  max-height: 72vh;
  object-fit: contain;
}

.senfa-price {
  position: absolute;
  bottom: 24px;
  left: 28px;
  background: #FEFCF8;
  padding: 16px 22px;
  z-index: 3;
  box-shadow: 0 2px 20px rgba(45,27,78,0.10);
  border-left: 3px solid #C9922A;
}
.senfa-price-label {
  font-family: 'Jost', sans-serif;
  font-size: 8px;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #8A7A9E;
  margin: 0 0 6px;
  font-weight: 300;
}
.senfa-price-amount {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 300;
  color: #2D1B4E;
  margin: 0 0 4px;
  line-height: 1;
}
.senfa-price-sub {
  font-family: 'Jost', sans-serif;
  font-size: 9px;
  color: #8A7A9E;
  font-weight: 300;
  margin: 0;
}

/* ── Scroll ── */
.senfa-scroll {
  position: absolute;
  left: 50%;
  bottom: 20px;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  z-index: 10;
}
.senfa-scroll-text {
  font-family: 'Jost', sans-serif;
  font-size: 7.5px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #8A7A9E;
  font-weight: 300;
}
.senfa-scroll-track {
  width: 1px;
  height: 36px;
  position: relative;
  overflow: hidden;
  background: rgba(201,146,42,0.15);
}
.senfa-scroll-bar {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  background: #C9922A;
  animation: senfa-scrollbar 1.8s ease-in-out infinite;
}

/* ── Animations ── */
.senfa-fade-up {
  opacity: 0;
  transform: translateY(24px);
  animation: senfa-fadeup 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}
@keyframes senfa-fadeup {
  to { opacity: 1; transform: translateY(0); }
}
@keyframes senfa-scrollbar {
  0%   { transform: translateY(-100%); opacity: 1; }
  100% { transform: translateY(100%);  opacity: 0.2; }
}

/* ════════════════════
   TABLET 1024px
════════════════════ */
@media (max-width: 1024px) {
  .senfa-hero {
    height: auto;
    min-height: calc(100vh - 75px);
    max-height: none;
  }
  .senfa-left {
    padding: 40px 40px 40px 48px;
  }
  .senfa-h1 {
    font-size: 48px;
  }
  .senfa-img {
    max-height: 55vh;
  }
}

/* ════════════════════
   MOBILE 768px
════════════════════ */
@media (max-width: 768px) {
  .senfa-hero {
    height: auto;
    min-height: auto;
    max-height: none;
  }
  .senfa-hero__inner {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
  }

  @media (max-width: 1024px) {
  .senfa-hero__inner {
    padding: 0 48px;
  }
}

@media (max-width: 768px) {
  .senfa-hero__inner {
    padding: 0;  /* left/right handled by .senfa-left padding on mobile */
  }
}
  .senfa-left {
    padding: 56px 24px 24px 24px;
    order: 1;
    justify-content: flex-start;
  }
  .senfa-tagline {
    margin-bottom: 12px;
  }
  .senfa-tagline span {
    font-size: 8.5px;
    letter-spacing: 2.5px;
  }
  .senfa-h1 {
    font-size: 36px;
    flex-direction: row;
    align-items: baseline;
    flex-wrap: nowrap;
    gap: 10px;
    letter-spacing: -0.5px;
    margin-bottom: 14px;
    line-height: 1.1;
    white-space: nowrap;
  }
  .senfa-word {
    display: inline;
  }
  .senfa-body {
    font-size: 13.5px;
    max-width: 100%;
    margin-bottom: 14px;
  }
  .senfa-badges {
    gap: 12px;
    margin-bottom: 20px;
  }
  .senfa-btns {
    flex-direction: column;
    align-items: center;
    gap: 14px;
    width: 100%;
  }
  .senfa-btn-primary {
    width: 100%;
    text-align: center;
    padding: 15px 24px;
    box-sizing: border-box;
  }
  .senfa-btn-ghost {
    text-align: center;
    width: 100%;
    display: block;
  }
  .senfa-right {
    order: 2;
    height: 64vw;
    min-height: 260px;
    max-height: 360px;
  }
  .senfa-imgwrap {
    padding: 16px 16px 72px 16px;
  }
  .senfa-img {
    max-height: 100%;
    width: auto;
  }
  .senfa-origin {
    top: 12px;
    right: 14px;
  }
  .senfa-origin-value { font-size: 13px; }
  .senfa-origin-label { font-size: 7px; }
  .senfa-price {
    position: absolute;
    bottom: 12px;
    left: 16px;
    right: auto;
    width: auto;
    display: block;
    background: #FEFCF8;
    padding: 10px 16px;
    box-shadow: 0 2px 12px rgba(45,27,78,0.10);
    border: 1px solid rgba(201,146,42,0.25);
    border-left: 3px solid #C9922A;
    box-sizing: border-box;
  }
  .senfa-price-label {
    font-size: 7px;
    letter-spacing: 2px;
    margin: 0 0 3px;
  }
  .senfa-price-amount {
    font-size: 22px;
    margin: 0 0 2px;
  }
  .senfa-price-sub {
    font-size: 8px;
    margin: 0;
  }
  .senfa-watermark {
    font-size: 48px;
    bottom: 12px;
  }
  .senfa-scroll { display: none; }
}

/* ════════════════════
   SMALL 480px
════════════════════ */
@media (max-width: 480px) {
  .senfa-left {
    padding: 52px 18px 20px 18px;
  }
  .senfa-h1 {
    font-size: 26px;
  }
  .senfa-line {
    width: 28px;
  }
  .senfa-badge {
    font-size: 8px;
    letter-spacing: 1.5px;
  }
}
</style>

{% schema %}
{
  "name": "Hero Section",
  "tag": "div",
  "class": "senfa-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Left Panel — Text"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "From the Saffron Fields of Kashmir"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading — Line 1 (normal)",
      "default": "Nature's"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading — Italic gold word",
      "default": "Rarest"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading — Line 2",
      "default": "Luxury"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "Hand-harvested Kashmiri saffron, cold-pressed into a soap that cleanses, soothes, and transforms. 100% vegan. Zero compromise."
    },
    {
      "type": "header",
      "content": "Badges"
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "Sulphate Free"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2",
      "default": "Paraben Free"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge 3",
      "default": "SLS Free"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Primary Button Label",
      "default": "Shop The Soap"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Primary Button URL"
    },
    {
      "type": "text",
      "id": "btn_ghost_label",
      "label": "Ghost Button Label",
      "default": "Discover Our Story"
    },
    {
      "type": "url",
      "id": "btn_ghost_url",
      "label": "Ghost Button URL"
    },
    {
      "type": "header",
      "content": "Right Panel — Product"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    },
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Watermark Text",
      "default": "SAFFRON"
    },
    {
      "type": "text",
      "id": "origin_label",
      "label": "Origin Label",
      "default": "Origin"
    },
    {
      "type": "text",
      "id": "origin_value",
      "label": "Origin Value",
      "default": "Kashmir, India"
    },
    {
      "type": "header",
      "content": "Price Card"
    },
    {
      "type": "text",
      "id": "price_label",
      "label": "Price Label",
      "default": "Starting From"
    },
    {
      "type": "text",
      "id": "price_amount",
      "label": "Price Amount",
      "default": "₹ 349"
    },
    {
      "type": "text",
      "id": "price_subtext",
      "label": "Price Subtext",
      "default": "Free shipping above ₹999"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}

</style>

<script>
class SenfaCartDrawer {
  constructor() {
    this.overlay = document.getElementById('senfa-cart-drawer');
    if (!this.overlay) return;
    
    this.drawer = this.overlay.querySelector('.scd-drawer');
    this.init();
  }

  init() {
    document.body.addEventListener('click', (e) => {
      const cartIcon = e.target.closest('a[href="/cart"], #cart-icon-bubble');
      if (cartIcon && !e.target.closest('.scd-drawer')) {
        e.preventDefault();
        this.refreshAndOpen();
      }
    });

    document.addEventListener('submit', (e) => {
      // Only intercept product add-to-cart forms, not other cart forms
      const form = e.target;
      if (!form.matches('form[action$="/cart/add"], form[action$="/cart/add.js"]')) return;
      // Skip if it's inside the cart drawer itself
      if (form.closest('#senfa-cart-drawer')) return;
      e.preventDefault();
      e.stopImmediatePropagation();
      this.addFormToCart(form);
    }, true);

    this.bindEvents();
  }

  bindEvents() {
    const closeBtn = this.overlay.querySelector('.scd-close');
    const closeEmptyBtn = this.overlay.querySelector('.scd-close-empty');
    
    if (closeBtn) closeBtn.addEventListener('click', () => this.close());
    if (closeEmptyBtn) closeEmptyBtn.addEventListener('click', () => this.close());
    
    this.overlay.addEventListener('click', (e) => {
      if (e.target === this.overlay) this.close();
    });

    this.drawer.querySelectorAll('.scd-qty-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        this.updateCart(btn.dataset.line, btn.dataset.qty);
      });
    });

    this.drawer.querySelectorAll('.scd-remove-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        this.updateCart(btn.dataset.line, 0);
      });
    });
  }

  open() {
    this.overlay.classList.add('scd-active');
    document.body.style.overflow = 'hidden';
  }

  close() {
    this.overlay.classList.remove('scd-active');
    document.body.style.overflow = '';
  }

  addFormToCart(form) {
    const formData = new FormData(form);
    const submitBtn = form.querySelector('[type="submit"], button[name="add"]');
    let originalText = '';
    
    if (submitBtn) {
      originalText = submitBtn.innerHTML;
      submitBtn.innerHTML = 'Adding...';
      submitBtn.disabled = true;
    }

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      body: formData
    })
    .then(response => response.json())
    .then(() => {
      if (submitBtn) {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
      }
      this.refreshAndOpen();
    })
    .catch(error => {
      console.error('Error adding item:', error);
      if (submitBtn) {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
      }
    });
  }

  updateCart(line, quantity) {
    this.drawer.classList.add('is-loading');
    fetch(window.Shopify.routes.root + 'cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: quantity })
    })
    .then(response => response.json())
    .then(() => this.refreshDOM())
    .catch(error => console.error('Error updating cart:', error));
  }

  refreshAndOpen() {
    this.open();
    this.drawer.classList.add('is-loading');
    this.refreshDOM();
  }

  /* ── FIX 2: Animate progress bar from 0 to target on every DOM refresh ── */
  refreshDOM() {
    fetch('?section_id=senfa-cart-drawer')
      .then(res => res.text())
      .then(html => {
        const parser = new DOMParser();
        const newDoc = parser.parseFromString(html, 'text/html');
        this.drawer.innerHTML = newDoc.querySelector('.scd-drawer').innerHTML;
        this.drawer.classList.remove('is-loading');

        /* Animate both the div fill and the ::before pseudo-element via custom property */
        const track = this.drawer.querySelector('.scd-progress-track');
        const fill = this.drawer.querySelector('.scd-progress-fill');
        if (fill && track) {
          const targetWidth = fill.style.width;

          /* Reset to 0 */
          fill.style.transition = 'none';
          fill.style.width = '0%';
          track.style.setProperty('--scd-fill', '0%');

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              fill.style.transition = 'width 0.6s cubic-bezier(0.25, 1, 0.5, 1)';
              fill.style.width = targetWidth;
              track.style.setProperty('--scd-fill', targetWidth);
            });
          });
        } else if (fill) {
          const targetWidth = fill.style.width;
          fill.style.transition = 'none';
          fill.style.width = '0%';
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              fill.style.transition = 'width 0.6s cubic-bezier(0.25, 1, 0.5, 1)';
              fill.style.width = targetWidth;
            });
          });
        }

        this.bindEvents();
        this.updateHeaderCount();
        this.autoApplyDiscount();
      });
  }

  updateHeaderCount() {
    fetch(window.Shopify.routes.root + 'cart.js')
      .then(res => res.json())
      .then(cart => {
        document.querySelectorAll('#cart-icon-bubble .cart-count-bubble span[aria-hidden="true"]').forEach(bubble => {
          bubble.textContent = cart.item_count;
        });
      });
  }

  /* ── Auto-apply discount code for the highest reached milestone ── */
  autoApplyDiscount() {
    const reached = this.drawer.querySelectorAll('.scd-milestone-reached[data-discount]');
    if (reached.length === 0) return;

    /* The last reached milestone with a discount code is the highest tier */
    const best = reached[reached.length - 1];
    const code = best.dataset.discount;
    if (!code) return;

    /* Only apply if it's different from what we last applied */
    if (this._lastAppliedDiscount === code) return;
    this._lastAppliedDiscount = code;


    fetch('/discount/' + encodeURIComponent(code), { method: 'GET' })
      .catch(() => { /* Discount apply failed silently */ });
  }
}

document.addEventListener('DOMContentLoaded', () => {
  if (!window.SenfaCartDrawerInstance) {
    window.SenfaCartDrawerInstance = new SenfaCartDrawer();
  }
});
</script>


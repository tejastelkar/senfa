/* Extra small phones */
@media (max-width: 375px) {
  .scd-header { padding: 14px 16px; }
  .scd-progress-wrapper { padding: 14px 16px 10px; }
  .scd-items { padding: 16px; }
  .scd-item-image { width: 75px; height: 100px; }
  .scd-totals-row { padding: 0 16px; }
  .scd-checkout-btn {
    width: calc(100% - 32px) !important;
    margin: 0 16px 16px !important;
  }
  .scd-trust-badges { padding: 12px 12px; }

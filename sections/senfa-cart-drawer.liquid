  .scd-footer > .scd-final-total:first-of-type { margin-top: 16px; }

  .scd-checkout-btn {
    width: calc(100% - 40px) !important;
    margin: 0 20px 20px !important;
    padding: 16px;
    font-size: 12px;
  }

  /* Progress bar milestones smaller on mobile */
  .scd-progress-milestone {
    width: 22px;

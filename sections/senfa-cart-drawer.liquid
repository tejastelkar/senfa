{% comment %}
  SENFA — Premium Slide-Out Cart Drawer (AJAX Enabled)
  File: sections/senfa-cart-drawer.liquid
{% endcomment %}

<div id="senfa-cart-drawer" class="scd-overlay" aria-hidden="true">
  <div class="scd-drawer">
    
    <div class="scd-loader"></div>

    <div class="scd-header">
      <h3 class="scd-title">{{ section.settings.drawer_title }}</h3>
      <button class="scd-close" aria-label="Close cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M18 6L6 18M6 6L18 18"/>
        </svg>
      </button>
    </div>

    {% if cart == empty %}
      <div class="scd-empty">
        <p class="scd-empty-text">{{ section.settings.empty_text }}</p>
        <button class="scd-continue-btn scd-close-empty">Continue Shopping</button>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post" id="scd-cart-form" class="scd-form">

        {% if section.settings.enable_offers_bar and section.blocks.size > 0 %}
          {% comment %} ── Determine current tracking value ── {% endcomment %}
          {% if section.settings.track_by == 'quantity' %}
            {% assign current_value = cart.item_count %}
          {% else %}
            {% assign current_value = cart.items_subtotal_price %}
          {% endif %}

          {% comment %} ── Find max threshold to scale the bar ── {% endcomment %}
          {% assign max_threshold = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'milestone' %}
              {% if section.settings.track_by == 'quantity' %}
                {% assign bval = block.settings.threshold_value %}
              {% else %}
                {% assign bval = block.settings.threshold_value | times: 100 %}
              {% endif %}
              {% if bval > max_threshold %}
                {% assign max_threshold = bval %}
              {% endif %}
            {% endif %}
          {% endfor %}

          {% comment %} ── Calculate fill percentage ── {% endcomment %}
          {% if max_threshold > 0 %}
            {% assign percent = current_value | times: 100.0 | divided_by: max_threshold %}
          {% else %}
            {% assign percent = 0 %}
          {% endif %}
          {% if percent > 100 %}{% assign percent = 100 %}{% endif %}

          {% comment %} ── Find the next unreached milestone for the message ── {% endcomment %}
          {% assign active_msg = section.settings.msg_all_unlocked %}
          {% assign found_next = false %}
          {% for block in section.blocks %}
            {% if block.type == 'milestone' and found_next == false %}
              {% if section.settings.track_by == 'quantity' %}
                {% assign bval = block.settings.threshold_value %}
              {% else %}
                {% assign bval = block.settings.threshold_value | times: 100 %}
              {% endif %}
              {% if current_value < bval %}
                {% assign found_next = true %}
                {% assign away = bval | minus: current_value %}
                {% if section.settings.track_by == 'quantity' %}
                  {% capture away_fmt %}<strong>{{ away }} item{% if away != 1 %}s{% endif %}</strong>{% endcapture %}
                {% else %}
                  {% capture away_fmt %}<strong>{{ away | money }}</strong>{% endcapture %}
                {% endif %}
                {% assign active_msg = block.settings.msg_approaching | replace: '[amount]', away_fmt %}
              {% endif %}
            {% endif %}
          {% endfor %}

          <div class="scd-progress-wrapper">
            <p class="scd-progress-text">
              {% if found_next %}
                {{ active_msg }}
              {% else %}
                <svg class="scd-inline-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                {{ active_msg }}
              {% endif %}
            </p>

            <div class="scd-progress-track" style="--scd-fill: {{ percent }}%;">
              <div class="scd-progress-fill" style="width: {{ percent }}%;"></div>

              {% for block in section.blocks %}
                {% if block.type == 'milestone' %}
                  {% if section.settings.track_by == 'quantity' %}
                    {% assign bval = block.settings.threshold_value %}
                  {% else %}
                    {% assign bval = block.settings.threshold_value | times: 100 %}
                  {% endif %}
                  {% assign mpos = bval | times: 100.0 | divided_by: max_threshold %}
                  <div class="scd-progress-milestone{% if current_value >= bval %} scd-milestone-reached{% endif %}"
                       style="left: {{ mpos }}%;"
                       {% if block.settings.discount_code != blank %}data-discount="{{ block.settings.discount_code }}"{% endif %}
                       {{ block.shopify_attributes }}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M20 12V22H4V12"/>
                      <path d="M22 7H2V12H22V7Z"/>
                      <path d="M12 22V7"/>
                      <path d="M12 7H7.5C6.119 7 5 5.881 5 4.5C5 3.119 6.119 2 7.5 2C8.881 2 10 3.119 10 4.5C10 5.419 11 7 12 7Z"/>
                      <path d="M12 7H16.5C17.881 7 19 5.881 19 4.5C19 3.119 17.881 2 16.5 2C15.119 2 14 3.119 14 4.5C14 5.419 13 7 12 7Z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            <div class="scd-progress-labels">
              {% for block in section.blocks %}
                {% if block.type == 'milestone' %}
                  {% if section.settings.track_by == 'quantity' %}
                    {% assign bval = block.settings.threshold_value %}
                  {% else %}
                    {% assign bval = block.settings.threshold_value | times: 100 %}
                  {% endif %}
                  {% assign mpos = bval | times: 100.0 | divided_by: max_threshold %}
                  <span class="scd-dynamic-label" style="left: {{ mpos }}%;">{{ block.settings.label }}</span>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        <div class="scd-items">
          {% for item in cart.items %}
            <div class="scd-item" data-line="{{ forloop.index }}">
              
              <div class="scd-item-image">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 400 }}" alt="{{ item.title | escape }}" loading="lazy">
                {% endif %}
              </div>

              <div class="scd-item-details">
                <div class="scd-item-header">
                  {%- if item.product.vendor != blank -%}
                    <span class="scd-item-vendor">{{ item.product.vendor }}</span>
                  {%- endif -%}
                  <a href="{{ item.url }}" class="scd-item-title">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="scd-item-variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                </div>

                <div class="scd-item-price-wrap">
                  {% if item.original_line_price > item.final_line_price %}
                    <span class="scd-item-compare">{{ item.original_line_price | money }}</span>
                  {% endif %}
                  <span class="scd-item-price">{{ item.final_line_price | money }}</span>
                </div>

                <div class="scd-item-actions">
                  <div class="scd-qty-selector">
                    <button type="button" class="scd-qty-btn scd-qty-minus" data-line="{{ forloop.index }}" data-qty="{{ item.quantity | minus: 1 }}">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8h10"/></svg>
                    </button>
                    <input type="text" class="scd-qty-input" value="{{ item.quantity }}" readonly>
                    <button type="button" class="scd-qty-btn scd-qty-plus" data-line="{{ forloop.index }}" data-qty="{{ item.quantity | plus: 1 }}">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 3v10M3 8h10"/></svg>
                    </button>
                  </div>
                  <button type="button" class="scd-remove-btn" data-line="{{ forloop.index }}">Remove</button>
                </div>
              </div>

            </div>
          {% endfor %}
        </div>

        <div class="scd-footer">
          
          <div class="scd-trust-badges">
            <div class="scd-trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                <line x1="9" y1="9" x2="9.01" y2="9"/>
                <line x1="15" y1="9" x2="15.01" y2="9"/>
              </svg>
              <span>1 MILLION +<br>HAPPY USERS</span>
            </div>
            <div class="scd-trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
              <span>SAFE & SECURE<br>DELIVERY</span>
            </div>
            <div class="scd-trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
              </svg>
              <span>WEBSITE<br>EXCLUSIVE OFFERS</span>
            </div>
          </div>

          {% assign total_compare = 0 %}
          {% for item in cart.items %}
            {% if item.variant.compare_at_price > item.price %}
              {% assign item_savings = item.variant.compare_at_price | minus: item.price | times: item.quantity %}
              {% assign total_compare = total_compare | plus: item_savings %}
            {% endif %}
          {% endfor %}

          {% if total_compare > 0 %}
            <div class="scd-totals-row scd-savings-row">
              <span>You Saved:</span>
              <span>{{ total_compare | money }}</span>
            </div>
          {% endif %}

          <div class="scd-totals-row scd-final-total">
            <span>Total:</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <button type="submit" name="checkout" class="scd-checkout-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
            {{ section.settings.checkout_text }} • {{ cart.total_price | money }}
          </button>
        </div>

      </form>
    {% endif %}

  </div>
</div>

<style>
/* ════════════════════════════════
   SENFA — LUXURY CART DRAWER
════════════════════════════════ */

.scd-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 99999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

.scd-overlay.scd-active {
  opacity: 1;
  pointer-events: auto;
}

.scd-drawer {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  max-width: 480px;
  background: #FFFFFF;
  box-shadow: -10px 0 40px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  font-family: 'Jost', sans-serif;
}

.scd-overlay.scd-active .scd-drawer {
  transform: translateX(0);
}

/* ── Smooth Loading Line (No Fade) ── */
.scd-drawer.is-loading {
  pointer-events: none;
}

.scd-loader {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: transparent;
  z-index: 100;
  overflow: hidden;
  display: none;
}

.scd-drawer.is-loading .scd-loader {
  display: block;
}

.scd-loader::after {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 40%;
  background: #C9922A; 
  animation: scdLoadingSweep 1s infinite ease-in-out;
}

@keyframes scdLoadingSweep {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(300%); }
}

/* Header */
.scd-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24px 36px;
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.scd-title {
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: #1A1228;
  margin: 0;
}

.scd-close {
  background: transparent;
  border: none;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #1A1228;
  padding: 0;
  transition: opacity 0.2s;
}

.scd-close:hover { opacity: 0.5; }
.scd-close svg { width: 20px; height: 20px; }

/* Empty State */
.scd-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  text-align: center;
}

.scd-empty-text {
  font-size: 16px;
  color: #4A4A4A;
  margin-bottom: 28px;
}

.scd-continue-btn {
  padding: 16px 40px;
  background: #1A1228;
  color: #FFFFFF;
  border: none;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.3s;
}
.scd-continue-btn:hover { background: #C9922A; }

/* Form Container */
.scd-form {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

/* ── Progress Bar ── */
.scd-progress-wrapper {
  padding: 24px 36px 16px;
  background: #FFFFFF;
  border-bottom: 1px solid rgba(0,0,0,0.04);
}

.scd-progress-text {
  font-size: 13px;
  color: #666;
  text-align: center;
  margin: 0 0 24px;
  letter-spacing: 0.05em;
}

.scd-progress-text strong {
  font-weight: 600;
  color: #1A1228;
}

.scd-inline-icon {
  width: 16px;
  height: 16px;
  vertical-align: -3px;
  display: inline-block;
  color: #C9922A;
  margin-right: 2px;
}

.scd-progress-track {
  width: 100% !important;
  height: 6px !important;
  min-height: 6px !important;
  background: #EAEAEA !important;
  position: relative !important;
  border-radius: 3px !important;
  overflow: visible !important;
  display: block !important;
}

/* Primary fill: pseudo-element driven by CSS custom property (theme-proof) */
.scd-progress-track::before {
  content: '' !important;
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
  height: 100% !important;
  width: var(--scd-fill, 0%) !important;
  background-color: #1A1228 !important;
  border-radius: 3px !important;
  z-index: 1 !important;
  transition: width 0.6s cubic-bezier(0.25, 1, 0.5, 1) !important;
}

/* Fallback fill: div-based (in case custom property is unsupported) */
.scd-progress-fill {
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
  height: 100% !important;
  min-height: 6px !important;
  background-color: #1A1228 !important;
  border-radius: 3px !important;
  z-index: 1 !important;
  transition: width 0.6s cubic-bezier(0.25, 1, 0.5, 1) !important;
  display: block !important;
}

/* ── Milestone icons — dynamically positioned via inline left % ── */
.scd-progress-milestone {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 26px;
  height: 26px;
  background: #FFFFFF;
  border: 2px solid #EAEAEA;
  border-radius: 50%;
  color: #E2481A;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  pointer-events: none;
  transition: border-color 0.3s, background 0.3s, color 0.3s;
}

.scd-progress-milestone svg {
  width: 14px;
  height: 14px;
  background: transparent;
}

/* Milestone reached state */
.scd-milestone-reached {
  border-color: #C9922A;
  background: #FFF8EE;
  color: #C9922A;
}

.scd-progress-labels {
  position: relative;
  width: 100%;
  height: 20px;
  margin-top: 14px;
  font-size: 10px;
  color: #999;
  letter-spacing: 0.05em;
}

.scd-dynamic-label {
  position: absolute;
  transform: translateX(-50%);
  white-space: nowrap;
}

/* ── Items List ── */
.scd-items {
  flex: 1;
  overflow-y: auto;
  padding: 32px 36px;
}

.scd-item {
  display: flex;
  gap: 24px;
  margin-bottom: 40px;
}

.scd-item:last-child {
  margin-bottom: 0;
}

.scd-item-image {
  width: 120px;
  height: 150px;
  background: #FAFAFA;
  border-radius: 4px;
  overflow: hidden;
  flex-shrink: 0;
  border: 1px solid rgba(0,0,0,0.03);
}

.scd-item-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.scd-item-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.scd-item-vendor {
  display: block;
  font-size: 10px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: #999;
  margin-bottom: 8px;
}

.scd-item-title {
  display: block;
  font-family: 'Jost', sans-serif;
  font-size: 15px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #1A1228;
  text-decoration: none;
  line-height: 1.4;
  margin-bottom: 8px;
}

.scd-item-variant {
  font-size: 13px;
  color: #666;
  margin: 0 0 12px;
}

.scd-item-price-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

.scd-item-compare {
  font-size: 14px;
  color: #999;
  text-decoration: line-through;
}

.scd-item-price {
  font-size: 17px;
  font-weight: 500;
  color: #1A1228;
}

.scd-item-actions {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-top: auto;
}

.scd-qty-selector {
  display: flex;
  align-items: center;
  border: 1px solid rgba(0,0,0,0.15);
  border-radius: 4px;
  height: 36px;
}

.scd-qty-btn {
  background: transparent;
  border: none;
  width: 36px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #1A1228;
}
.scd-qty-btn svg { width: 12px; height: 12px; }

.scd-qty-input {
  width: 32px;
  height: 100%;
  border: none;
  text-align: center;
  font-family: 'Jost', sans-serif;
  font-size: 14px;
  color: #1A1228;
  pointer-events: none;
  background: transparent;
}

.scd-remove-btn {
  background: transparent;
  border: none;
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  letter-spacing: 0.05em;
  color: #666;
  text-decoration: underline;
  text-underline-offset: 4px;
  cursor: pointer;
  padding: 0;
  transition: color 0.2s;
}

.scd-remove-btn:hover { color: #C9922A; }

/* ── Footer ── */
.scd-footer {
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
}

/* Trust Badges */
.scd-trust-badges {
  display: flex;
  justify-content: space-between;
  padding: 20px 36px;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
  background: #FAFAFA;
}

.scd-trust-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 8px;
  flex: 1;
}

.scd-trust-badge svg {
  width: 18px;
  height: 18px;
  color: #1A1228;
  stroke-width: 1.2px;
}

.scd-trust-badge span {
  font-size: 8px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #666;
  line-height: 1.4;
}

/* Totals */
.scd-totals-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 36px;
  font-size: 14px;
  color: #666;
  letter-spacing: 0.05em;
}

.scd-savings-row {
  color: #C9922A;
  margin-top: 24px;
  margin-bottom: 12px;
}

.scd-final-total {
  font-weight: 500;
  color: #1A1228;
  font-size: 18px;
  margin-bottom: 24px;
}
.scd-savings-row + .scd-final-total { margin-top: 0; }
.scd-footer > .scd-final-total:first-of-type { margin-top: 24px; }

.scd-checkout-btn {
  width: calc(100% - 72px);
  margin: 0 36px 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 20px;
  background: #1A1228;
  color: #FFFFFF;
  border: none;
  border-radius: 4px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.3s;
}

.scd-checkout-btn svg { width: 16px; height: 16px; }
.scd-checkout-btn:hover { background: #C9922A; }

/* ═══════════════════════════════════
   MOBILE RESPONSIVE — FULL FIX
═══════════════════════════════════ */
@media (max-width: 768px) {
  /* Force overlay to cover entire viewport on mobile */
  .scd-overlay {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    width: 100% !important;
    height: 100% !important;
    height: 100dvh !important;
    z-index: 999999 !important;
  }

  /* Full-width drawer on mobile */
  .scd-drawer {
    max-width: 100% !important;
    width: 100% !important;
    height: 100% !important;
    height: 100dvh !important;
  }

  .scd-header { padding: 16px 20px; }
  .scd-progress-wrapper { padding: 16px 20px 12px; }
  .scd-progress-text { font-size: 12px; margin-bottom: 18px; }

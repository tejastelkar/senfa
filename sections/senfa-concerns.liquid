    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body Text",
      "default": "Targeted Ayurvedic rituals for your specific skin needs."
    },
    {
      "type": "header",
      "content": "Colors (Fully Editable)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#1A1228"
    },
    {
      "type": "color",
      "id": "accent_gold",

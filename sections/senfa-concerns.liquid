      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 160, "step": 8, "default": 104, "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "concern_card",
      "name": "Concern Card",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text (Optional)",

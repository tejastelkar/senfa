          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Senfa Shop By Concern",
      "blocks": [
        {
          "type": "concern_card",
          "settings": {
            "title": "Skin Ageing",

{% comment %}
  Senfa — Shop By Concern (Premium Editorial Grid - Fixed Image Layout)
  File: sections/senfa-concerns.liquid
{% endcomment %}

<section class="senfa-concerns" id="senfa-concerns-{{ section.id }}" style="
  --bg-color: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --accent-gold: {{ section.settings.accent_gold }};
  --text-body: {{ section.settings.text_body }};
  --card-bg: {{ section.settings.card_bg }};
  --card-text: {{ section.settings.card_text }};
">
  <div class="senfa-concerns__inner">

    {%- comment -%} ── STANDARDIZED UTILITY HEADER ── {%- endcomment -%}
    <div class="senfa-concerns__header-standard">
      {%- if section.settings.heading != blank -%}
        <h2 class="senfa-concerns__heading-centered">
          {{ section.settings.heading }}
          {%- if section.settings.heading_italic != blank -%}
            <br><em>{{ section.settings.heading_italic }}</em>
          {%- endif -%}
        </h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="senfa-concerns__body-centered">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── CONCERNS GRID ── {%- endcomment -%}
    <div class="senfa-concerns__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="senfa-concern-card" {{ block.shopify_attributes }}>
          
          <div class="scc__content">
            {%- if block.settings.eyebrow != blank -%}
              <span class="scc__eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="scc__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <p class="scc__desc">{{ block.settings.description }}</p>
            {%- endif -%}

            <div class="scc__btn">
              <span>{{ block.settings.btn_label | default: 'Explore' }}</span>
              <svg class="scc__btn-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </div>

          <div class="scc__image-wrap">
            {%- if block.settings.image != blank -%}
              <img 
                src="{{ block.settings.image | image_url: width: 600 }}" 
                alt="{{ block.settings.image.alt | default: block.settings.title }}" 
                class="scc__image"
                loading="lazy"
              >
            {%- else -%}
              <div class="scc__placeholder"></div>
            {%- endif -%}
          </div>

        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
/* ════════════════════════════════
   SENFA — SHOP BY CONCERN
════════════════════════════════ */

.senfa-concerns {
  background-color: var(--bg-color);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.senfa-concerns__inner {
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 80px;
}

/* ══════════════════════════════════════════════
   STANDARDIZED CENTERED HEADER
══════════════════════════════════════════════ */

.senfa-concerns__header-standard {
  text-align: center;
  max-width: 800px;
  margin: 0 auto 56px;
  padding: 0 40px;
}

.senfa-concerns__heading-centered {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 4.5vw, 56px);
  font-weight: 400;
  color: var(--heading-color);
  margin: 0 0 20px;
  letter-spacing: -0.01em;
  text-transform: none !important;
  line-height: 1.1;
}

.senfa-concerns__heading-centered em {
  font-style: italic;
  color: var(--accent-gold);
  font-weight: 400;
}

.senfa-concerns__body-centered {
  font-family: 'Jost', sans-serif;
  font-size: 16px;
  line-height: 1.8;
  color: var(--text-body);
  font-weight: 300;
  margin: 0;
}

/* ── GRID LAYOUT ── */
.senfa-concerns__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

/* ── CARD STYLING ── */
.senfa-concern-card {
  display: flex;
  flex-direction: column;
  background-color: var(--card-bg);
  border-radius: 4px;
  overflow: hidden;
  text-decoration: none;
  aspect-ratio: 3 / 4; /* Tall editorial ratio */
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease;
  border: 1px solid rgba(0,0,0,0.03);
}

.senfa-concern-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 40px rgba(26, 18, 40, 0.08);
}

/* Text Content (Fixed at Top) */
.scc__content {
  padding: 40px 32px 24px 32px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex: 0 0 auto; /* Takes only the space it needs */
  z-index: 2;
}

.scc__eyebrow {
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent-gold);
  margin-bottom: 12px;
}

.scc__title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 500;
  color: var(--card-text);
  margin: 0 0 12px;
  line-height: 1.15;
}

.scc__desc {
  font-family: 'Jost', sans-serif;
  font-size: 14.5px;
  font-weight: 300;
  color: var(--card-text);
  opacity: 0.8;
  margin: 0 0 20px;
  line-height: 1.6;
  max-width: 95%;
}

/* Minimalist Explore Button (Safely Below Text) */
.scc__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--card-text);
  border-bottom: 1px solid transparent;
  padding-bottom: 2px;
  transition: color 0.3s ease;
}

.scc__btn-arrow {
  width: 14px;
  height: 14px;
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

.senfa-concern-card:hover .scc__btn {
  color: var(--accent-gold);
}

.senfa-concern-card:hover .scc__btn-arrow {
  transform: translateX(6px);
  color: var(--accent-gold);
}

/* Image Wrapper (Fills remaining bottom space) */
.scc__image-wrap {
  flex: 1 1 auto; /* Expands to fill rest of card */
  width: 100%;
  position: relative;
  overflow: hidden;
  min-height: 0; /* Important for flex child */
}

.scc__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center; /* Keeps portrait faces centered */
  transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  display: block;
}

.senfa-concern-card:hover .scc__image {
  transform: scale(1.05);
}

.scc__placeholder {
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.03);
}

/* ════════════════
   TABLET 1024px
════════════════ */
@media (max-width: 1024px) {
  .senfa-concerns__inner {
    padding: 0 48px;
  }
  .senfa-concerns__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .scc__content {
    padding: 32px 24px 20px 24px;
  }
}

/* ════════════════
   MOBILE 768px (Horizontal Swipe)
════════════════ */
@media (max-width: 768px) {
  .senfa-concerns {
    padding: 80px 0;
  }
  
  .senfa-concerns__inner {
    padding: 0; /* Remove horizontal padding so slider bleeds to edges */
  }

  .senfa-concerns__header-standard {
    padding: 0 24px;
    margin-bottom: 40px;
  }
  
  .senfa-concerns__heading-centered {
    font-size: clamp(32px, 8vw, 40px);
  }

  /* Native CSS Swipe Slider */
  .senfa-concerns__grid {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; 
    -ms-overflow-style: none; 
    gap: 16px;
    padding: 0 24px 20px 24px;
    margin: 0;
  }
  
  .senfa-concerns__grid::-webkit-scrollbar {
    display: none; 
  }

  .senfa-concern-card {
    flex: 0 0 calc(100vw - 64px); 
    max-width: 320px;
    scroll-snap-align: center;
    aspect-ratio: 3 / 4; 
  }

  .scc__content {
    padding: 28px 24px 20px 24px;
  }
  
  .scc__title {
    font-size: 24px;
  }
}

/* ════════════════
   SMALL 480px
════════════════ */
@media (max-width: 480px) {
  .senfa-concerns__grid {
    padding: 0 16px 20px 16px;
    gap: 12px;
  }
  .senfa-concern-card {
    flex: 0 0 calc(100vw - 48px);
  }
}
</style>

{% schema %}
{
  "name": "Senfa Shop By Concern",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Concern"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading Italic Line",

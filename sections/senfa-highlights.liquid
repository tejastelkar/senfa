{% comment %}
  Senfa — Highlights / Awards Grid (Instagram 4:5 Ratio)
  File: sections/senfa-highlights.liquid
{% endcomment %}

<section class="senfa-highlights" id="senfa-highlights-{{ section.id }}" style="
  --bg-color: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --accent-gold: {{ section.settings.accent_gold }};
  --text-body: {{ section.settings.text_body }};
  --btn-bg: {{ section.settings.btn_bg }};
  --btn-text: {{ section.settings.btn_text }};
  --footer-btn-bg: {{ section.settings.footer_btn_bg }};
  --footer-btn-text: {{ section.settings.footer_btn_text }};
  --footer-btn-hover-bg: {{ section.settings.footer_btn_hover_bg }};
  --footer-btn-hover-text: {{ section.settings.footer_btn_hover_text }};
">
  <div class="senfa-highlights__inner">

    {%- comment -%} ── STANDARDIZED UTILITY HEADER (Clean & Centered) ── {%- endcomment -%}
    <div class="senfa-highlights__header-standard">
      {%- if section.settings.heading != blank -%}
        <h2 class="senfa-highlights__heading-centered">
          {{ section.settings.heading }}
          {%- if section.settings.heading_italic != blank -%}
            <br><em>{{ section.settings.heading_italic }}</em>
          {%- endif -%}
        </h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="senfa-highlights__body-centered">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── HIGHLIGHTS GRID ── {%- endcomment -%}
    <div class="senfa-highlights__grid">
      {%- for block in section.blocks -%}
        <div class="senfa-highlights__card" {{ block.shopify_attributes }}>
          
          <div class="sh-card__image-wrap">
            {%- if block.settings.image != blank -%}
              <img 
                src="{{ block.settings.image | image_url: width: 800 }}" 
                alt="{{ block.settings.image.alt | default: block.settings.title }}" 
                class="sh-card__image"
                loading="lazy"
              >
            {%- else -%}
              <div class="sh-card__placeholder">
                <span>SENFA VISUAL</span>
              </div>
            {%- endif -%}
          </div>

          <div class="sh-card__content">
            {%- if block.settings.eyebrow != blank -%}
              <span class="sh-card__eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="sh-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.subtitle != blank -%}
              <p class="sh-card__subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}

            {%- if block.settings.btn_label != blank and block.settings.btn_url != blank -%}
              <a href="{{ block.settings.btn_url }}" class="sh-card__btn">
                {{ block.settings.btn_label }}
              </a>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} ── GLOBAL SECTION FOOTER BUTTON ── {%- endcomment -%}
    {%- if section.settings.footer_btn_label != blank and section.settings.footer_btn_url != blank -%}
      <div class="senfa-highlights__footer">
        <a href="{{ section.settings.footer_btn_url }}" class="senfa-highlights__view-all-btn">
          <span>{{ section.settings.footer_btn_label }}</span>
          <svg class="sh-btn-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
/* ════════════════════════════════
   SENFA — HIGHLIGHTS ARCHITECTURE
════════════════════════════════ */

.senfa-highlights {
  background-color: var(--bg-color);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.senfa-highlights__inner {
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 80px;
}

/* ══════════════════════════════════════════════
   STANDARDIZED CENTERED HEADER
══════════════════════════════════════════════ */

.senfa-highlights__header-standard {
  text-align: center;
  max-width: 800px;
  margin: 0 auto 64px;
  padding: 0 40px;
}

.senfa-highlights__heading-centered {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 4.5vw, 56px);
  font-weight: 400;
  color: var(--heading-color);
  margin: 0 0 24px;
  letter-spacing: -0.01em;
  text-transform: none !important;
  line-height: 1.1;
}

.senfa-highlights__heading-centered em {
  font-style: italic;
  color: var(--accent-gold);
  font-weight: 400;
}

.senfa-highlights__body-centered {
  font-family: 'Jost', sans-serif;
  font-size: 16px;
  line-height: 1.8;
  color: var(--text-body);
  font-weight: 300;
  margin: 0;
}

/* ── GRID LAYOUT ── */
.senfa-highlights__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}

/* ── CARD STYLING ── */
.senfa-highlights__card {
  display: flex;
  flex-direction: column;
  width: 100%;
}

/* Instagram Portrait 4:5 Ratio */
.sh-card__image-wrap {
  width: 100%;
  aspect-ratio: 4 / 5;
  background-color: #F5F3EE;
  position: relative;
  overflow: hidden;
  margin-bottom: 24px;
}

.sh-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  display: block;
}

.senfa-highlights__card:hover .sh-card__image {
  transform: scale(1.05);
}

.sh-card__placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  letter-spacing: 0.25em;
  color: var(--accent-gold);
  text-transform: uppercase;
}

/* Card Content (Typography Hierarchy) */
.sh-card__content {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sh-card__eyebrow {
  font-family: 'Jost', sans-serif;
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-body);
  opacity: 0.7;
  margin-bottom: 10px;
}

.sh-card__title {
  font-family: 'Jost', sans-serif;
  font-size: 16px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--heading-color);
  margin: 0 0 8px;
  line-height: 1.3;
}

.sh-card__subtitle {
  font-family: 'Jost', sans-serif;
  font-size: 13.5px;
  font-weight: 300;
  color: var(--text-body);
  margin: 0 0 24px;
  line-height: 1.4;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Internal Card Button */
.sh-card__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 40px;
  background: var(--btn-bg);
  color: var(--btn-text);
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  text-decoration: none;
  border: 1px solid var(--btn-bg);
  transition: all 0.4s ease;
  min-width: 180px;
  margin-top: auto;
}

.sh-card__btn:hover {
  background: var(--accent-gold);
  border-color: var(--accent-gold);
  color: #FFFFFF;
}

/* ── GLOBAL SECTION FOOTER BUTTON ── */
.senfa-highlights__footer {
  margin-top: 64px;
  display: flex;
  justify-content: center;
}

.senfa-highlights__view-all-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 16px 48px;
  background: var(--footer-btn-bg);
  color: var(--footer-btn-text);
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  text-decoration: none;
  border: 1px solid var(--footer-btn-bg);
  transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

.senfa-highlights__view-all-btn .sh-btn-arrow {
  width: 14px;
  height: 14px;
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

.senfa-highlights__view-all-btn:hover {
  background: var(--footer-btn-hover-bg);
  border-color: var(--footer-btn-hover-bg);
  color: var(--footer-btn-hover-text);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(201, 146, 42, 0.2);
}

.senfa-highlights__view-all-btn:hover .sh-btn-arrow {
  transform: translateX(6px);
}

/* ════════════════
   TABLET 1024px
════════════════ */
@media (max-width: 1024px) {
  .senfa-highlights__inner {
    padding: 0 48px;
  }
  .senfa-highlights__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 48px 32px;
  }
}

/* ════════════════
   MOBILE 768px (Horizontal Swipe Carousel)
════════════════ */
@media (max-width: 768px) {
  .senfa-highlights {
    padding: 80px 0;
  }
  .senfa-highlights__header-standard {
    padding: 0 24px;
    margin-bottom: 40px;
  }
  .senfa-highlights__heading-centered {
    font-size: 36px;
  }
  
  .senfa-highlights__inner {
    padding: 0; /* Remove side padding so slider bleeds to edge */
  }

  /* Transform Grid into Native CSS Slider */
  .senfa-highlights__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE */
    gap: 16px;
    padding: 0 24px 20px 24px;
  }
  .senfa-highlights__grid::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .senfa-highlights__card {
    flex: 0 0 80%; /* Show 80% of card so next one peeks in */
    scroll-snap-align: center;
  }

  .sh-card__image-wrap {
    margin-bottom: 20px;
  }

  .sh-card__title {
    font-size: 15px;
  }

  .senfa-highlights__footer {
    margin-top: 40px;
    padding: 0 24px;
  }

  .senfa-highlights__view-all-btn {
    width: 100%;
  }
}

/* ════════════════
   SMALL 480px
════════════════ */
@media (max-width: 480px) {
  .senfa-highlights__grid {
    padding: 0 16px 20px 16px;
  }
  .senfa-highlights__card {
    flex: 0 0 85%;
  }
}
</style>


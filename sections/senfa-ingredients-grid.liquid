{% comment %}
  SENFA — Ingredient Spotlight Grid (Premium White Editorial)
  File: sections/senfa-ingredients-grid.liquid
{% endcomment %}

<section id="sig-{{ section.id }}" class="senfa-ingredients-grid" style="
  --bg-color: {{ section.settings.bg_color }};
  --card-bg: {{ section.settings.card_bg }};
  --heading-color: {{ section.settings.heading_color }};
  --text-body: {{ section.settings.text_body }};
  --accent-gold: {{ section.settings.accent_gold }};
">
  <div class="sig-container">

    {%- comment -%} ── STANDARDIZED UTILITY HEADER ── {%- endcomment -%}
    <header class="sig-header-standard">
      {%- if section.settings.eyebrow_text != blank -%}
        <div class="sig-eyebrow-centered">
          <span>{{ section.settings.eyebrow_text }}</span>
        </div>
      {%- endif -%}

      <h2 class="sig-heading-centered">
        {{ section.settings.title_line1 }}
        {%- if section.settings.title_line2 != blank -%}
          <br><em>{{ section.settings.title_line2 }}</em>
        {%- endif -%}
      </h2>
    </header>

    {%- comment -%} ── EDITORIAL GRID ── {%- endcomment -%}
    <div class="sig-grid" role="list">
      {% for block in section.blocks %}
        {% if block.type == 'ingredient' %}
          <div class="sig-card" role="listitem" {{ block.shopify_attributes }}>
            
            <div class="sig-card-top">
              <span class="sig-origin">{{ block.settings.origin }}</span>
              <span class="sig-index">0{{ forloop.index }}</span>
            </div>

            <div class="sig-icon-wrap">
              {% if block.settings.icon_image != blank %}
                <img
                  src="{{ block.settings.icon_image | image_url: width: 240 }}"
                  alt="{{ block.settings.ingredient_name }}"
                  class="sig-icon"
                  loading="lazy"
                  width="120"
                  height="120"
                >
              {% else %}
                {% case forloop.index %}
                {% when 1 %}
                  <svg class="sig-icon" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="60" cy="60" r="12" fill="var(--accent-gold)" opacity="0.15"/>
                    <ellipse cx="60" cy="30" rx="4" ry="18" fill="var(--heading-color)" opacity="0.2" transform="rotate(0 60 60)"/>
                    <ellipse cx="60" cy="30" rx="4" ry="18" fill="var(--heading-color)" opacity="0.15" transform="rotate(60 60 60)"/>
                    <ellipse cx="60" cy="30" rx="4" ry="18" fill="var(--heading-color)" opacity="0.15" transform="rotate(120 60 60)"/>
                    <ellipse cx="60" cy="30" rx="4" ry="18" fill="var(--heading-color)" opacity="0.1" transform="rotate(180 60 60)"/>
                    <ellipse cx="60" cy="30" rx="4" ry="18" fill="var(--heading-color)" opacity="0.1" transform="rotate(240 60 60)"/>
                    <ellipse cx="60" cy="30" rx="4" ry="18" fill="var(--heading-color)" opacity="0.1" transform="rotate(300 60 60)"/>
                    <line x1="60" y1="48" x2="60" y2="24" stroke="var(--accent-gold)" stroke-width="1.5" opacity="0.8"/>
                    <line x1="56" y1="26" x2="60" y2="24" stroke="var(--accent-gold)" stroke-width="1" opacity="0.6"/>
                    <line x1="64" y1="26" x2="60" y2="24" stroke="var(--accent-gold)" stroke-width="1" opacity="0.6"/>
                    <circle cx="60" cy="22" r="2.5" fill="var(--accent-gold)" opacity="0.9"/>
                  </svg>
                {% when 2 %}
                  <svg class="sig-icon" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M48 40 Q60 20 72 40 Q80 56 72 68 Q60 80 48 68 Q40 56 48 40Z" fill="var(--heading-color)" opacity="0.05"/>
                    <path d="M52 44 Q60 28 68 44 Q74 56 68 66 Q60 74 52 66 Q46 56 52 44Z" fill="var(--accent-gold)" opacity="0.15"/>
                    <circle cx="60" cy="54" r="4" fill="var(--accent-gold)" opacity="0.4"/>
                    <path d="M44 42 Q48 34 54 42" stroke="var(--heading-color)" stroke-width="1" fill="none" opacity="0.2"/>
                  </svg>
                {% when 3 %}
                  <svg class="sig-icon" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="34" y="56" width="52" height="10" rx="5" fill="var(--heading-color)" opacity="0.08"/>
                    <rect x="40" y="48" width="10" height="18" rx="5" fill="var(--accent-gold)" opacity="0.15" transform="rotate(-20 45 57)"/>
                    <rect x="66" y="46" width="10" height="20" rx="5" fill="var(--accent-gold)" opacity="0.15" transform="rotate(15 71 56)"/>
                    <circle cx="60" cy="61" r="3" fill="var(--accent-gold)" opacity="0.4"/>
                  </svg>
                {% when 4 %}
                  <svg class="sig-icon" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="60" cy="60" r="16" fill="var(--heading-color)" opacity="0.05"/>
                    <path d="M60 46 Q68 52 68 60 Q68 68 60 74 Q52 68 52 60 Q52 52 60 46Z" fill="var(--accent-gold)" opacity="0.15"/>
                    <path d="M48 52 Q54 48 60 52 Q60 62 54 66 Q46 62 48 52Z" fill="var(--accent-gold)" opacity="0.1"/>
                    <path d="M72 52 Q78 62 72 68 Q66 62 60 52 Q66 48 72 52Z" fill="var(--accent-gold)" opacity="0.1"/>
                    <circle cx="60" cy="60" r="4" fill="var(--accent-gold)" opacity="0.4"/>
                  </svg>
                {% else %}
                  <svg class="sig-icon" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="60" cy="60" r="24" stroke="var(--accent-gold)" stroke-width="1" opacity="0.3"/>
                    <circle cx="60" cy="60" r="12" fill="var(--heading-color)" opacity="0.05"/>
                    <circle cx="60" cy="60" r="4" fill="var(--accent-gold)" opacity="0.4"/>
                  </svg>
                {% endcase %}
              {% endif %}
            </div>

            <div class="sig-content">
              <h3 class="sig-name">{{ block.settings.ingredient_name }}</h3>
              {% if block.settings.latin_name != blank %}
                <p class="sig-latin">{{ block.settings.latin_name }}</p>
              {% endif %}
              
              <div class="sig-divider"></div>
              
              <div class="sig-benefits">
                {% if block.settings.benefit_1 != blank %}
                  <p>{{ block.settings.benefit_1 }}</p>
                {% endif %}
                {% if block.settings.benefit_2 != blank %}
                  <p>{{ block.settings.benefit_2 }}</p>
                {% endif %}
              </div>
            </div>

          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
/* ════════════════════════════════
   SENFA — INGREDIENT GRID
════════════════════════════════ */

.senfa-ingredients-grid {
  background-color: var(--bg-color);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.sig-container {
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 80px;
}

/* ══════════════════════════════════════════════
   STANDARDIZED CENTERED HEADER
══════════════════════════════════════════════ */

.sig-header-standard {
  text-align: center;
  max-width: 800px;
  margin: 0 auto 64px;
  padding: 0 40px;
  opacity: 0;
  transform: translateY(20px);
  animation: sigFadeUp 0.8s ease forwards;
}

.sig-eyebrow-centered {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--accent-gold);
  margin-bottom: 24px;
}
.sig-eyebrow-centered::before,
.sig-eyebrow-centered::after {
  content: '';
  width: 32px;
  height: 1px;
  background: currentColor;
  opacity: 0.6;
}

.sig-heading-centered {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 4.5vw, 56px);
  font-weight: 400;
  color: var(--heading-color);
  margin: 0;
  letter-spacing: -0.01em;
  text-transform: none !important;
  line-height: 1.1;
}

.sig-heading-centered em {
  font-style: italic;
  color: var(--accent-gold);
  font-weight: 400;
}

/* ── GRID ARCHITECTURE ── */
.sig-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

/* ── EDITORIAL CARD ── */
.sig-card {
  background: var(--card-bg);
  border: 1px solid rgba(0,0,0,0.04);
  padding: 40px 32px;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.5s ease, border-color 0.5s ease;
  opacity: 0;
  transform: translateY(30px);
}

.sig-card.sig-visible {
  opacity: 1;
  transform: translateY(0);
}

.sig-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 24px 48px rgba(0,0,0,0.03);
  border-color: rgba(201,146,42,0.2); /* Faint gold glow */
}

/* Card Top (Origin & Index) */
.sig-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
}

.sig-origin {
  font-family: 'Jost', sans-serif;
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent-gold);
  display: flex;
  align-items: center;
  gap: 8px;
}
.sig-origin::before {
  content: '';
  width: 12px;
  height: 1px;
  background: currentColor;
  opacity: 0.5;
}

.sig-index {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  font-style: italic;
  color: var(--heading-color);
  opacity: 0.3;
}

/* Icon Wrap */
.sig-icon-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 120px;
  margin-bottom: 40px;
}

.sig-icon {
  width: 100px;
  height: 100px;
  object-fit: contain;
  transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
}

.sig-card:hover .sig-icon {
  transform: scale(1.05) translateY(-4px);
}

/* Content Area */
.sig-content {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-grow: 1;
}

.sig-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 26px;
  font-weight: 400;
  color: var(--heading-color);
  margin: 0 0 4px;
  line-height: 1.1;
}

.sig-latin {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  font-style: italic;
  color: var(--text-body);
  opacity: 0.6;
  margin: 0 0 20px;
}

.sig-divider {
  width: 24px;
  height: 1px;
  background: var(--accent-gold);
  opacity: 0.4;
  margin: 0 auto 24px;
}

.sig-benefits p {
  font-family: 'Jost', sans-serif;
  font-size: 13.5px;
  font-weight: 300;
  line-height: 1.6;
  color: var(--text-body);
  margin: 0 0 8px;
}
.sig-benefits p:last-child {
  margin-bottom: 0;
  opacity: 0.7; /* Secondary benefit is slightly faded */
}

@keyframes sigFadeUp {
  to { opacity: 1; transform: translateY(0); }
}

/* ════════════════
   TABLET 1024px
════════════════ */
@media (max-width: 1024px) {
  .sig-container { padding: 0 48px; }
  .sig-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
}

/* ════════════════
   MOBILE 768px (Horizontal Swipe)
════════════════ */
@media (max-width: 768px) {
  .senfa-ingredients-grid { padding: 80px 0; }
  
  .sig-container { padding: 0; }

  .sig-header-standard {
    padding: 0 24px;
    margin-bottom: 40px;
  }
  
  .sig-heading-centered { font-size: 36px; }

  /* Native CSS Swipe Slider */
  .sig-grid {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; 
    gap: 16px;
    padding: 0 24px 20px 24px;
  }
  
  .sig-grid::-webkit-scrollbar { display: none; }

  .sig-card {
    flex: 0 0 calc(100vw - 64px); 
    max-width: 320px;
    scroll-snap-align: center;
    padding: 32px 24px;
  }
}

/* ════════════════
   SMALL 480px
════════════════ */
@media (max-width: 480px) {
  .sig-grid { padding: 0 16px 20px 16px; gap: 12px; }
  .sig-card { flex: 0 0 calc(100vw - 48px); }
}
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const section = document.getElementById('sig-{{ section.id }}');
    if (!section) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          // Staggered reveal for cards
          setTimeout(() => {
            entry.target.classList.add('sig-visible');
          }, index * 100);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    section.querySelectorAll('.sig-card').forEach(el => {
      observer.observe(el);
    });
  });
</script>


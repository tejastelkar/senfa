{% comment %}
  Section: Senfa Real Results
  File: sections/senfa-real-results.liquid
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  .srr-section {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    font-family: 'Jost', sans-serif;
    color: #000000;
  }

  .srr-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 80px;
    box-sizing: border-box;
  }

  /* ════════════════════════
     HEADER (Matched to FAQ)
  ════════════════════════ */
  .srr-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .srr-eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: #000000; 
    margin: 0 0 16px 0;
    text-transform: none !important; /* Force override of theme global styles */
  }

  .srr-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 3.5vw, 46px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: #000000;
    margin: 0;
    text-transform: none !important; /* Force override of theme global styles */
  }

  /* ════════════════════════
     GRID & BOXES
  ════════════════════════ */
  .srr-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  .srr-box {
    border: 1px solid rgba(0,0,0,0.15);
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    background: transparent;
  }

  .srr-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(72px, 7vw, 110px);
    font-weight: 300;
    line-height: 1;
    color: #000000;
    margin: 0 0 20px 0;
    letter-spacing: -0.02em;
  }

  .srr-text {
    font-family: 'Jost', sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.5;
    color: #000000;
    margin: 0 0 40px 0;
  }
  .srr-text strong {
    font-weight: 600;
  }

  .srr-disclaimer {
    margin-top: auto;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: rgba(0,0,0,0.5);
  }

  .srr-image-box {
    padding: 0;
    overflow: hidden;
    position: relative;
    min-height: 400px;
  }
  
  .srr-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .srr-image-placeholder {
    position: absolute;
    inset: 0;
    background: #F3F3F3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0,0,0,0.3);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .srr-container { padding: 0 40px; }
    .srr-grid { grid-template-columns: 1fr; gap: 20px; }
    .srr-image-box { min-height: 500px; order: -1; }
    .srr-box { padding: 40px 30px; }
  }

  @media (max-width: 768px) {
    .srr-container { padding: 0 20px; }
    .srr-image-box { min-height: 350px; }
    .srr-title { font-size: 32px; }
  }
</style>

<section class="srr-section">
  <div class="srr-container">
    
    <div class="srr-header">
      {% if section.settings.eyebrow != blank %}
        <p class="srr-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="srr-title">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="srr-grid">
      <div class="srr-box">
        <div class="srr-number">{{ section.settings.stat_1_num }}</div>
        <div class="srr-text">{{ section.settings.stat_1_text }}</div>
        <div class="srr-disclaimer">{{ section.settings.stat_1_disclaimer }}</div>
      </div>
      <div class="srr-box srr-image-box">
        {% if section.settings.center_image != blank %}
          <img src="{{ section.settings.center_image | img_url: '800x' }}" alt="Before and After Results" class="srr-image" loading="lazy">
        {% else %}
          <div class="srr-image-placeholder">Image Container</div>
        {% endif %}
      </div>
      <div class="srr-box">
        <div class="srr-number">{{ section.settings.stat_2_num }}</div>
        <div class="srr-text">{{ section.settings.stat_2_text }}</div>
        <div class="srr-disclaimer">{{ section.settings.stat_2_disclaimer }}</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Senfa Real Results",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Real Stories" },
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Real Results" },
    { "type": "header", "content": "Left Box" },
    { "type": "text", "id": "stat_1_num", "label": "Big Number", "default": "94%" },
    { "type": "richtext", "id": "stat_1_text", "label": "Description Text", "default": "<p>Users Noticed a Visible <strong>Reduction In Tanning.</strong></p>" },
    { "type": "text", "id": "stat_1_disclaimer", "label": "Disclaimer text", "default": "* Results shown are based on customer feedback" },
    { "type": "header", "content": "Center Image" },
    { "type": "image_picker", "id": "center_image", "label": "Before / After Image" },
    { "type": "header", "content": "Right Box" },
    { "type": "text", "id": "stat_2_num", "label": "Big Number", "default": "91%" },
    { "type": "richtext", "id": "stat_2_text", "label": "Description Text", "default": "<p>Agreed Their Skin Became <strong>Even Toned.</strong></p>" },
    { "type": "text", "id": "stat_2_disclaimer", "label": "Disclaimer text", "default": "* Results shown are based on customer feedback" }
  ],
  "presets": [{ "name": "Senfa Real Results" }]
}
{% endschema %}
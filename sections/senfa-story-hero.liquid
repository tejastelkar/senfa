{% comment %}
  Section: senfa-story-hero (Redesigned)
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">

<style>
  #senfa-hero-{{ section.id }} {
    min-height: 100vh;
    background: linear-gradient(135deg, #2D1B4E 0%, #4A2D78 50%, #2D1B4E 100%);
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
    font-family: 'Jost', sans-serif;
    z-index: 0;
  }

  /* Ambient orbs */
  #senfa-hero-{{ section.id }}::before {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    top: -120px; left: -80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,146,42,0.07), transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  #senfa-hero-{{ section.id }}::after {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    bottom: -80px; right: 5%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(107,74,158,0.3), transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  /* Center divider */
  .sh-divider-{{ section.id }} {
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom,
      transparent,
      rgba(201,146,42,0.2) 25%,
      rgba(201,146,42,0.2) 75%,
      transparent
    );
    z-index: 3;
    pointer-events: none;
  }

  /* ── LEFT PANEL ── */
  .sh-left-{{ section.id }} {
    padding: 180px 60px 70px 80px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    z-index: 2;
  }

  .sh-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 9px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #E0B84E;
    font-weight: 400;
    margin-bottom: 22px;
    opacity: 0;
    animation: shFadeUp 0.9s 0.3s forwards;
  }
  .sh-eyebrow::before {
    content: '';
    width: 28px; height: 1px;
    background: #C9922A;
    flex-shrink: 0;
  }

  .sh-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(58px, 6.5vw, 100px);
    font-weight: 300;
    line-height: 0.92;
    color: #FEFCF8;
    margin: 0 0 8px;
    letter-spacing: -1.5px;
    opacity: 0;
    animation: shFadeUp 1s 0.5s forwards;
  }
  .sh-title-italic {
    display: block;
    font-style: italic;
    color: #E0B84E;
    font-size: clamp(66px, 7.5vw, 112px);
    padding-left: 44px;
    line-height: 1.0;
  }

  .sh-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 28px;
    opacity: 0;
    animation: shFadeUp 0.9s 0.8s forwards;
  }
  .sh-meta-line { width: 20px; height: 1px; background: rgba(201,146,42,0.35); }
  .sh-meta-text { font-size: 9px; letter-spacing: 2.5px; color: rgba(255,255,255,0.3); font-weight: 300; }

  .sh-memory {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 18px;
    padding: 11px 18px;
    border: 1px solid rgba(201,146,42,0.2);
    background: rgba(201,146,42,0.04);
    width: fit-content;
    opacity: 0;
    animation: shFadeUp 0.9s 1.05s forwards;
  }
  .sh-memory-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #C9922A;
    flex-shrink: 0;
    animation: shPulse 2.5s ease-in-out infinite;
  }
  .sh-memory-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-style: italic;
    color: rgba(255,255,255,0.45);
    font-weight: 300;
  }

  .sh-scroll-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    opacity: 0;
    animation: shFadeIn 1s 1.5s forwards;
  }
  .sh-scroll-line { width: 40px; height: 1px; background: linear-gradient(to right, #C9922A, transparent); }
  .sh-scroll-label { font-size: 8px; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.22); }

  /* ── RIGHT PANEL ── */
  .sh-right-{{ section.id }} {
    padding: 180px 80px 70px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 18px;
    position: relative;
    z-index: 2;
  }

  .sh-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border: 1px solid rgba(201,146,42,0.25);
    background: rgba(201,146,42,0.06);
    width: fit-content;
    opacity: 0;
    animation: shFadeUp 0.9s 0.6s forwards;
  }
  .sh-badge-dot { width: 4px; height: 4px; border-radius: 50%; background: #E0B84E; }
  .sh-badge-text { font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase; color: #E0B84E; }

  .sh-founder-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(201,146,42,0.18);
    padding: 22px 24px;
    opacity: 0;
    animation: shFadeUp 0.9s 0.75s forwards;
  }
  .sh-founder-label { font-size: 8px; letter-spacing: 3px; text-transform: uppercase; color: #E0B84E; margin-bottom: 10px; }
  .sh-founder-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-style: italic;
    color: #FEFCF8;
    font-weight: 300;
    margin: 0 0 6px;
  }
  .sh-founder-sub { font-size: 9px; letter-spacing: 2px; color: rgba(255,255,255,0.28); text-transform: uppercase; }

  .sh-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    opacity: 0;
    animation: shFadeUp 0.9s 0.9s forwards;
  }
  .sh-stat-box {
    background: rgba(45,27,78,0.7);
    border: 1px solid rgba(201,146,42,0.14);
    padding: 18px 20px;
  }
  .sh-stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 300;
    color: #E0B84E;
    line-height: 1;
    margin-bottom: 5px;
  }
  .sh-stat-label { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.3); line-height: 1.5; }

  .sh-pillars {
    display: flex;
    border: 1px solid rgba(201,146,42,0.14);
    opacity: 0;
    animation: shFadeUp 0.9s 1.05s forwards;
  }
  .sh-pillar-item {
    flex: 1;
    padding: 14px 16px;
    border-right: 1px solid rgba(201,146,42,0.1);
  }
  .sh-pillar-item:last-child { border-right: none; }
  .sh-pillar-title { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
  .sh-pillar-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-style: italic;
    color: #E0B84E;
    line-height: 1.4;
  }

  /* Keyframes */
  @keyframes shFadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes shFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes shPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(1.5); }
  }

  /* Mobile */
  @media (max-width: 768px) {
    #senfa-hero-{{ section.id }} {
      grid-template-columns: 1fr;
    }
    .sh-divider-{{ section.id }} { display: none; }
    .sh-left-{{ section.id }} {
      padding: 140px 28px 40px;
    }
    .sh-right-{{ section.id }} {
      padding: 0 28px 60px;
      justify-content: flex-start;
    }
    .sh-title { font-size: clamp(52px, 13vw, 80px); }
    .sh-title-italic { font-size: clamp(58px, 14vw, 88px); padding-left: 28px; }
  }

  @media (max-width: 480px) {
    .sh-left-{{ section.id }} { padding: 120px 20px 32px; }
    .sh-right-{{ section.id }} { padding: 0 20px 48px; }
    .sh-stats-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<section id="senfa-hero-{{ section.id }}" aria-label="{{ section.settings.eyebrow_text }}">

  <div class="sh-divider-{{ section.id }}" aria-hidden="true"></div>

  <!-- LEFT: Story content -->
  <div class="sh-left-{{ section.id }}">
    <div>
      <div class="sh-eyebrow">{{ section.settings.eyebrow_text }}</div>

      <h1 class="sh-title">
        {{ section.settings.title_line1 }}
        <span class="sh-title-italic">{{ section.settings.title_line2 }}</span>
      </h1>

      <div class="sh-meta">
        <div class="sh-meta-line"></div>
        <span class="sh-meta-text">{{ section.settings.meta_text }}</span>
      </div>

      {% if section.settings.memory_text != blank %}
      <div class="sh-memory">
        <span class="sh-memory-dot"></span>
        <span class="sh-memory-text">{{ section.settings.memory_text }}</span>
      </div>
      {% endif %}
    </div>

    <div class="sh-scroll-{{ section.id }}">
      <div class="sh-scroll-line"></div>
      <span class="sh-scroll-label">{{ section.settings.scroll_label }}</span>
    </div>
  </div>

  <!-- RIGHT: Brand credentials -->
  <div class="sh-right-{{ section.id }}">

    <div class="sh-badge">
      <div class="sh-badge-dot"></div>
      <span class="sh-badge-text">{{ section.settings.right_badge }}</span>
    </div>

    <div class="sh-founder-card">
      <div class="sh-founder-label">Founded by</div>
      <div class="sh-founder-name">{{ section.settings.founder_name }}</div>
      <div class="sh-founder-sub">{{ section.settings.founder_sub }}</div>
    </div>

    <div class="sh-stats-grid">
      <div class="sh-stat-box">
        <div class="sh-stat-num">{{ section.settings.stat1_number }}</div>
        <div class="sh-stat-label">{{ section.settings.stat1_label }}</div>
      </div>
      <div class="sh-stat-box">
        <div class="sh-stat-num">{{ section.settings.stat2_number }}</div>
        <div class="sh-stat-label">{{ section.settings.stat2_label }}</div>
      </div>
    </div>

    <div class="sh-pillars">
      <div class="sh-pillar-item">
        <div class="sh-pillar-title">Purity</div>
        <div class="sh-pillar-val">Uncompromised</div>
      </div>
      <div class="sh-pillar-item">
        <div class="sh-pillar-title">Heritage</div>
        <div class="sh-pillar-val">Family Grown</div>
      </div>
      <div class="sh-pillar-item">
        <div class="sh-pillar-title">Integrity</div>
        <div class="sh-pillar-val">A Father's Standard</div>
      </div>
    </div>

  </div>

</section>

{% schema %}
{
  "name": "Story Hero",
  "tag": "section",
  "class": "senfa-story-hero",
  "settings": [
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow Label", "default": "The Unfinished Conversation" },
    { "type": "text", "id": "title_line1", "label": "Title — Line 1", "default": "A Son's" },
    { "type": "text", "id": "title_line2", "label": "Title — Line 2 (italic gold)", "default": "Promise." },
    { "type": "text", "id": "meta_text", "label": "Meta / Location", "default": "Est. 2023 · Kashmir, India" },
    { "type": "text", "id": "memory_text", "label": "Memory Dedication (blank to hide)", "default": "In memory of Abhay Manik Birla" },
    { "type": "text", "id": "scroll_label", "label": "Scroll Cue", "default": "Read the story" },
    { "type": "text", "id": "right_badge", "label": "Right Panel Badge", "default": "The Inheritance" },
    { "type": "text", "id": "founder_name", "label": "Founder Name", "default": "The Birla Family" },
    { "type": "text", "id": "founder_sub", "label": "Founder Subtitle", "default": "Pune, Maharashtra · Senfa" },
    { "type": "text", "id": "stat1_number", "label": "Stat 1 Number", "default": "150+" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 Label", "default": "Acres of Saffron Farms" },
    { "type": "text", "id": "stat2_number", "label": "Stat 2 Number", "default": "100%" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 Label", "default": "Kashmiri Origin" }
  ],
  "presets": [{ "name": "Story Hero" }]
}
{% endschema %}
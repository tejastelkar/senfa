        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Image"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Customer Name",
          "default": "Sunny Arora"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Senfa Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "These multifunctional products simplify my routine and keep me looking and feeling my best, wherever I go.",
            "author_name": "Sunny Arora"
          }
        },
        {

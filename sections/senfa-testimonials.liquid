            "author_name": "Aisha Patel"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "The scent of genuine Himalayan saffron is unmistakable. True luxury in a bar of soap.",
            "author_name": "Rohan Mehta"
          }
        }
      ]
    }
  ]
}
{% endschema %}